# Secrets only. Copy to .env and fill in. Never commit .env.
# Everything that is not a secret belongs in config.json.

# From @BotFather after /newbot
TELEGRAM_BOT_TOKEN=replace_with_botfather_token

# One or more comma-separated private/group destinations. Filled in by:
# python3 configure_telegram.py, --group, or --both
TELEGRAM_CHAT_IDS=

# Legacy single-destination fallback. New installs can leave this blank.
TELEGRAM_CHAT_ID=
